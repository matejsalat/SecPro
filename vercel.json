{
  "framework": null,
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/aml-check.js": {
      "maxDuration": 60,
      "memory": 512
    },
    "api/*.js": {
      "maxDuration": 30,
      "includeFiles": "lib/**"
    }
  }
}
