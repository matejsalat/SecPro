{
  "framework": null,
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "functions": {
    "api/aml-check.js": {
      "maxDuration": 60,
      "memory": 512
    },
    "api/orsr.js": {
      "maxDuration": 60
    },
    "api/*.js": {
      "maxDuration": 30,
      "includeFiles": "lib/**"
    },
    "api/sign/*.js": {
      "maxDuration": 15,
      "includeFiles": "lib/**"
    }
  }
}
